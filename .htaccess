# =============================================================================
# Laravel .htaccess for Shared Hosting (Remove /public from URL)
# =============================================================================
# Place this file in the ROOT of your hosting (public_html or www)
# Rename it to .htaccess
# =============================================================================

<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # --------------------------------------------------------------------------
    # 1. Force HTTPS (uncomment if SSL is installed)
    # --------------------------------------------------------------------------
    # RewriteCond %{HTTPS} !=on
    # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # --------------------------------------------------------------------------
    # 2. Handle Authorization Header (required for API / Sanctum / Passport)
    # --------------------------------------------------------------------------
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # --------------------------------------------------------------------------
    # 3. Handle X-XSRF-Token Header (required for Livewire / CSRF)
    # --------------------------------------------------------------------------
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # --------------------------------------------------------------------------
    # 4. Serve static assets directly from /public (css, js, images, fonts, etc.)
    # --------------------------------------------------------------------------
    RewriteCond %{REQUEST_URI} ^/build/(.*)$
    RewriteRule ^build/(.*)$ public/build/$1 [L]

    RewriteCond %{REQUEST_URI} ^/vendor/(.*)$
    RewriteRule ^vendor/(.*)$ public/vendor/$1 [L]

    RewriteCond %{REQUEST_URI} ^/storage/(.*)$
    RewriteRule ^storage/(.*)$ public/storage/$1 [L]

    RewriteCond %{REQUEST_URI} ^/favicon\.ico$
    RewriteRule ^favicon\.ico$ public/favicon.ico [L]

    RewriteCond %{REQUEST_URI} ^/robots\.txt$
    RewriteRule ^robots\.txt$ public/robots.txt [L]

    # --------------------------------------------------------------------------
    # 5. Redirect Trailing Slashes If Not A Folder
    # --------------------------------------------------------------------------
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # --------------------------------------------------------------------------
    # 6. Route everything else through public/index.php (Front Controller)
    # --------------------------------------------------------------------------
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/$1 [L]

    # --------------------------------------------------------------------------
    # 7. Bypass Composer Platform Requirements (Redis extension version conflict)
    # --------------------------------------------------------------------------
    SetEnv COMPOSER_IGNORE_PLATFORM_REQS 1
    
</IfModule>

# =============================================================================
# Security Headers
# =============================================================================
<IfModule mod_headers.c>
    # Prevent clickjacking
    Header set X-Frame-Options "SAMEORIGIN"

    # Prevent MIME-type sniffing
    Header set X-Content-Type-Options "nosniff"

    # XSS Protection
    Header set X-XSS-Protection "1; mode=block"

    # Referrer Policy
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # Remove server signature
    Header unset X-Powered-By
    Header unset Server
</IfModule>

# =============================================================================
# Block access to sensitive files & directories
# =============================================================================
<FilesMatch "^\.env|\.env\..*|composer\.json|composer\.lock|package\.json|package-lock\.json|artisan|webpack\.mix\.js|vite\.config\.js$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Block access to hidden files (starting with .)
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# =============================================================================
# Compression (Gzip)
# =============================================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE application/xml application/xhtml+xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# =============================================================================
# Cache Static Assets
# =============================================================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
</IfModule>
